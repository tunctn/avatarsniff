{
  "name": "avatarsniff",
  "version": "0.1.0",
  "description": "Sniff out generic/default provider avatars (Google's initial-on-colour, Gravatar mystery-person, solid placeholders) straight from image pixels. Framework-agnostic, zero dependencies.",
  "type": "module",
  "license": "MIT",
  "author": "Tunç Türkmen <t@tunc.co>",
  "homepage": "https://github.com/tunctn/avatarsniff#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tunctn/avatarsniff.git"
  },
  "bugs": {
    "url": "https://github.com/tunctn/avatarsniff/issues"
  },
  "keywords": [
    "avatar",
    "default-avatar",
    "placeholder",
    "google",
    "gravatar",
    "image",
    "detection",
    "profile-picture"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    },
    "./webp": {
      "import": { "types": "./dist/webp.d.ts", "default": "./dist/webp.js" },
      "require": { "types": "./dist/webp.d.cts", "default": "./dist/webp.cjs" }
    },
    "./svg": {
      "import": { "types": "./dist/svg.d.ts", "default": "./dist/svg.js" },
      "require": { "types": "./dist/svg.d.cts", "default": "./dist/svg.cjs" }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "webp": ["./dist/webp.d.ts"],
      "svg": ["./dist/svg.d.ts"]
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "attw": "attw --pack .",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@jsquash/webp": "^1.5.0",
    "@resvg/resvg-wasm": "^2.6.2",
    "@vitest/coverage-v8": "^2.1.8",
    "jpeg-js": "^0.4.4",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
